# ── App ────────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*

# ── AWS / DynamoDB ─────────────────────────────────────────────────────────────
# Local development (LocalStack via docker-compose):
DYNAMO_ENDPOINT=http://localhost:4566
DYNAMO_TABLE_NAME=focus-reading
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Production (real AWS — remove DYNAMO_ENDPOINT, set real credentials):
# DYNAMO_TABLE_NAME=focus-reading-prod
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=<from IAM role or env>
# AWS_SECRET_ACCESS_KEY=<from IAM role or env>

# ── Spotify Web API (OAuth2 PKCE) ──────────────────────────────────────────────
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# ── Claude / Anthropic API ─────────────────────────────────────────────────────
# https://console.anthropic.com
# If absent, the mock playlist composer is used automatically (no AI calls)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

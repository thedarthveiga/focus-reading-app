{
  "name": "focus-reading-app",
  "version": "0.1.0",
  "description": "Neuroscience-based reading focus app — Hexagonal Architecture MVP",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/src/adapters/input/rest/server.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/adapters/input/rest/server.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern='tests/unit'",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern='tests/integration'",
    "test:arch": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern='tests/architecture'",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --forceExit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "db:create": "DYNAMO_ENDPOINT=http://localhost:4566 ts-node infra/scripts/createTable.ts",
    "db:seed": "DYNAMO_ENDPOINT=http://localhost:4566 ts-node infra/scripts/seed.ts",
    "db:setup": "npm run db:create && npm run db:seed",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@aws-sdk/client-dynamodb": "^3.540.0",
    "@aws-sdk/lib-dynamodb": "^3.540.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dependency-cruiser": "^16.3.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
